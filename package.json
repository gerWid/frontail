{
  "name": "frontail",
  "version": "5.0.0",
  "description": "streaming logs to the browser",
  "homepage": "https://github.com/gerwid/frontail",
  "author": "Maciej Winnicki <maciej.winnicki@gmail.com>",
  "contributors": [
    "gerwid <gerrit@die-wideras.de>"
  ],
  "license": "MIT",
  "bin": "./bin/frontail",
  "dependencies": {
    "CBuffer": "^0.1.4",
    "basic-auth-connect": "^1.1.0",
    "byline": "^5.0.0",
    "command-exists": "^1.2.9",
    "commander": "^3.0.1",
    "connect": "^3.7.0",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "daemon-fix41": "^1.1.2",
    "express-session": "^1.18.1",
    "fs-tail-stream": "^1.1.0",
    "serve-static": "^2.2.0",
    "socket.io": "^4.8.1",
    "untildify": "^3.0.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.9.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "jsdom": "~11.12.0",
    "mocha": "^10.8.2",
    "should": "^13.2.3",
    "sinon": "^17.0.1",
    "supertest": "^7.1.4",
    "temp": "^0.9.4"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "mocha -r should --exit test/*.js",
    "pkg": "pkg --out-path=dist ."
  },
  "engines": {
    "node": ">=18"
  },
  "pkg": {
    "assets": [
      "preset/*.json",
      "web/**/*"
    ],
    "targets": [
      "node20-alpine-x64",
      "node20-linux-x64",
      "node20-macos-x64",
      "node20-win-x64"
    ]
  },
  "eslintConfig": {
    "extends": [
      "airbnb-base",
      "prettier"
    ],
    "rules": {
      "no-console": "off",
      "strict": "off",
      "implicit-arrow-linebreak": "off"
    },
    "env": {
      "node": true
    },
    "ignorePatterns": [
      "web/assets/tinycon.min.js",
      "web/assets/ansi_up.js"
    ]
  },
  "prettier": {
    "singleQuote": true,
    "arrowParens": "always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gerwid/frontail.git"
  },
  "keywords": [
    "tail",
    "syslog",
    "realtime",
    "log",
    "devops"
  ],
  "main": "index",
  "preferGlobal": true
}
